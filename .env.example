# Admin UI credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=local-test-only-change-this-password

# Optional: canonical external URL for CSRF origin checks behind reverse proxies
# Example: https://your-app.up.railway.app
TRUSTED_ORIGIN=

# Optional for the standalone admin UI, but required when the upstream
# Hermes Workspace runs as a separate service and needs server-to-server access.
# Set the same value on both the Hermes service and the hermes-workspace service.
# Leave blank only if you are using the browser admin UI directly with basic auth.
HERMES_API_TOKEN=

# Hermes gateway startup behavior
HERMES_AUTO_START=true
HERMES_INFERENCE_PROVIDER=ollama
HERMES_DEFAULT_MODEL=kimi-k2.5:cloud

# Local compose default: http://ollama:11434
# Railway private network example:
# http://${{YOUR_OLLAMA_SERVICE.RAILWAY_PRIVATE_DOMAIN}}:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=

# Optional Codex-compatible local endpoint.
# Example: http://host.docker.internal:4317/v1
# For CLI-only local Codex, leave this blank and set CODEX_CLI_ENABLED=true.
CODEX_BASE_URL=
# Recommended for Railway and other non-interactive deploys.
# If omitted, Hermes expects a persisted Codex login under CODEX_HOME/auth.json.
CODEX_API_KEY=

# Optional: use local Codex CLI instead of an HTTP endpoint.
# Requires the `codex` binary (or CODEX_CLI_BIN) to be reachable from Hermes.
# Hermes containers default CODEX_HOME to /data/.hermes/.codex so `codex login`
# persists alongside the rest of Hermes state.
# CODEX_HOME=/data/.hermes/.codex
CODEX_CLI_ENABLED=false
CODEX_CLI_BIN=codex
CODEX_CLI_SANDBOX=read-only
CODEX_CLI_APPROVAL_MODE=never
# CODEX_CLI_CWD=/absolute/path/to/workspace
# CODEX_CLI_ARGS=

# OpenRouter remains available by switching provider to openrouter.
OPENROUTER_API_KEY=

# Hermes Workspace sidecar settings when running the upstream UI container.
HERMES_WORKSPACE_PORT=3000

# UI Mode: set to "true" to use the original admin panel instead of the new React UI
USE_LEGACY_UI=false
